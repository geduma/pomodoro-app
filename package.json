{
  "name": "pomodoro-app",
  "productName": "Pomodoro App",
  "version": "1.0.0",
  "description": "pomodoro-app app",
  "private": true,
  "main": "dist/electron/main/main.js",
  "scripts": {
    "web:dev": "vite",
    "web:build": "rimraf dist/ && vue-tsc --noEmit && vite build",
    "app:dev": "npm run web:build && tsc && electron .",
    "app:build": "rimraf release/ && npm run web:build && tsc && electron-builder",
    "build": "npm run web:build"
  },
  "build": {
    "appId": "geduma_pomodoro_app",
    "asar": true,
    "directories": {
      "buildResources": "assets",
      "output": "release/${version}"
    },
    "files": [
      "dist"
    ],
    "mac": {
      "icon": "dist/icon.icns",
      "artifactName": "${productName}.${ext}",
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "icon": "dist/icon.png",
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "win": {
      "icon": "dist/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    }
  },
  "keywords": [],
  "author": "geduma",
  "license": "ISC",
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "bootstrap": "5.2.3",
    "vue": "3.2.45",
    "vue-router": "4.1.6"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/tsconfig": "^0.1.3",
    "concurrently": "^7.6.0",
    "esbuild": "^0.28.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "electron-packager": "^17.1.1",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.0.1",
    "ts-standard": "^12.0.2",
    "typescript": "~4.7.4",
    "vite": "^8.1.0",
    "vue-tsc": "^1.0.12"
  },
  "eslintConfig": {
    "parserOptions": {
      "project": "./tsconfig.json"
    },
    "extends": [
      "./node_modules/ts-standard/eslintrc.json"
    ]
  }
}
